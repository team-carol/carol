# Cloudflare Tunnel Token
# Cloudflare Zero Trust → Networks → Tunnels → Create Tunnel → Docker
CF_TUNNEL_TOKEN=your-tunnel-token-here

# PostgreSQL (required by docker-compose; use a real secret locally)
POSTGRES_DB=carol
POSTGRES_USER=carol
POSTGRES_PASSWORD=replace-with-a-long-random-secret
DATABASE_URL=postgresql://carol:replace-with-a-long-random-secret@postgres:5432/carol

# XRSS (패치노트 소스) — X 계정 자격증명
# 공식 계정이 아닌 스크레이핑 전용 버너 계정 권장. 트윗을 "읽기"만 하는 용도.
TWITTER_USERNAME=your-x-handle
TWITTER_EMAIL=your-x-email
TWITTER_PASSWORD=your-x-password
# 2FA(TOTP)가 켜진 계정만 필요. 없으면 비워두면 됨.
TWITTER_TOTP_SECRET=
